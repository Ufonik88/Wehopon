# HandshakeLab lab configuration — copy to lab.toml and customize.
# Never commit lab.toml with real production BSSIDs to a public repo.

[lab]
name = "Your Lab Bench"
operator = "your-name"
# false = any scanned SSID can be tested after UI checkbox (password unknown is OK)
require_authorization = false

# Add every AP you are authorized to test.
[[allowed_targets]]
ssid = "LAB-AP-01"
bssid = "AA:BB:CC:DD:EE:FF"
owner = "Your Company QA"
authorization_ref = "QA-TICKET-001"

[capture]
default_adapter = "wlan1"
default_duration_sec = 300
# Controlled deauth is disruptive — lab-only, off by default.
deauth_enabled = false

[crack]
hashcat_bin = "/usr/bin/hashcat"
wordlist = "/path/to/your-internal-qa-wordlist.txt"
workload_profile = 2

[ui]
# Web UI: checking the authorization box is enough for ad-hoc lab targets
trust_operator_ack = true
default_port = 8765

# Optional AI wordlist (set env HANDSHAKELAB_AI_API_KEY)
# export HANDSHAKELAB_AI_API_KEY=sk-...
# export HANDSHAKELAB_AI_BASE_URL=https://api.openai.com/v1